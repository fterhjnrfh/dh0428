<Window x:Class="Example_Demo.Source.View.DeviceSampleFreqWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Example_Demo.Source.View" WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="设备频率列表" Height="300" Width="500">
    <ScrollViewer>
        <ItemsControl x:Name="itemsDevice" Margin="5">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Height="30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="设备ID:" VerticalAlignment="Center"></TextBlock>
                        <TextBox Text="{Binding DeviceInfo,Mode=OneWay}" IsEnabled="False" Grid.Column="1" VerticalAlignment="Center"></TextBox>
                        <CheckBox Content="是否读取数据" IsChecked="{Binding ReadData}" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"></CheckBox>
                        <ComboBox ItemsSource="{Binding SampleFreqs}" SelectedItem="{Binding CurrentSamplefreq}" Grid.Column="3" 
                                  SelectionChanged="ComboBox_SelectionChanged" VerticalAlignment="Center"></ComboBox>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Window>
