<local:BaseView x:Class="Example_Demo.IOView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Example_Demo"
             mc:Ignorable="d" >
    <local:BaseView.Resources>
        <local:IOColorConverter x:Key="colorConverter"></local:IOColorConverter>
    </local:BaseView.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <ScrollViewer Focusable="False" VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Auto">
            <DataGrid x:Name="datagrid" Margin="5,5,0,0"  HorizontalAlignment="Left"
                      RowHeight="25"  Width="300" SelectionUnit="FullRow" AutoGenerateColumns="False" CanUserAddRows="False"
                      VerticalScrollBarVisibility="Auto" VirtualizingStackPanel.IsVirtualizing="True"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto" SelectionMode="Single">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsSelected"  Value="True">
                                <Setter Property="Background" Value="LightBlue"></Setter>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"></Condition>
                                    <Condition Property="IsSelected"  Value="False"></Condition>
                                </MultiTrigger.Conditions>
                            </MultiTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="tcChannel" Header="通道"  IsReadOnly="True"  Binding="{Binding ID}" Width="100"/>
                    <DataGridTextColumn Header="I/O"  IsReadOnly="True"  Binding="{Binding IOStatus}" Width="60"/>

                    <DataGridTemplateColumn Header="实时值(点击切换)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Data}" MouseLeftButtonDown="TextBlock_MouseLeftButtonDown"
                                           HorizontalAlignment="Stretch" TextAlignment="Center"
                                           Background="{Binding Data,Converter={StaticResource colorConverter}}"></TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </ScrollViewer>
        <TextBlock Grid.Column="1" Text="启动采样后,单击实时值切换IO输出;仅DO通道(TTL)可切换" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="20" Foreground="Red"></TextBlock>
    </Grid>
</local:BaseView>
