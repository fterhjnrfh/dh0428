<Window x:Class="AutoStartVirtualInstrument.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoStartVirtualInstrument"
        mc:Ignorable="d"
        Title="MainWindow" Height="300" Width="300">
    <Grid>
        <TabControl>
            <TabItem Header="启动程序">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                    </StackPanel.Resources>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="目的IP" />
                        <TextBox Text="{Binding ComputerIPaddress}" Width="150"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="首台仪器机号" />
                        <TextBox Text="{Binding StartMachineID}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="启动仪器数量" />
                        <TextBox Text="{Binding StartMachineCount}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="单台仪器通道数" />
                        <TextBox Text="{Binding ChannelCount}"/>
                    </StackPanel>
                    <Button Content="启动模拟仪器" Click="Button_Click"></Button>
                </StackPanel>
            </TabItem>
            <TabItem Header="配置Mac文件">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                    </StackPanel.Resources>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="首台仪器IP" />
                        <TextBox Text="{Binding StartLocalIP}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="配置仪器数量" />
                        <TextBox Text="{Binding ConfigMachineCount}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="目标端口" />
                        <TextBox Text="{Binding DestPort}" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="信号源类型" />
                        <ComboBox SelectedIndex="{Binding WaveType}" Width="100">
                            <ComboBoxItem Content="正弦定频"/>
                            <ComboBoxItem Content="正弦扫频"/>
                            <ComboBoxItem Content="直流"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="信号源频率" />
                        <TextBox Text="{Binding Frequency}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="信号源幅值" />
                        <TextBox Text="{Binding Amplitude}"/>
                    </StackPanel>
                    <Button Content="配置Mac" Click="Button_Config_Click" ></Button>
                </StackPanel>
            </TabItem>
            <TabItem Header="配置DeviceInfo.ini">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="Label">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Width" Value="100"></Setter>
                        </Style>
                    </StackPanel.Resources>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="首台仪器IP" />
                        <TextBox Text="{Binding StartDeviceInfoLocalIP}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="配置仪器数量" />
                        <TextBox Text="{Binding DeviceInfoMachineCount}"/>
                    </StackPanel>
                    <Button Content="配置DeviceInfo.ini" Click="Button_ConfigDevice_Click" ></Button>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
